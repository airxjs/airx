{
  "name": "airx",
  "version": "0.8.0",
  "description": "a front framework with jsx",
  "type": "module",
  "types": "./output/index.d.ts",
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "default": "./output/index.js"
    },
    "./jsx-runtime": {
      "types": "./output/jsx-runtime.d.ts",
      "import": "./output/jsx-runtime.js",
      "default": "./output/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./output/jsx-dev-runtime.d.ts",
      "import": "./output/jsx-dev-runtime.js",
      "default": "./output/jsx-dev-runtime.js"
    }
  },
  "files": [
    "output/index.js",
    "output/index.d.ts",
    "output/index.umd.cjs",
    "output/jsx-runtime.js",
    "output/jsx-runtime.d.ts",
    "output/jsx-dev-runtime.js",
    "output/jsx-dev-runtime.d.ts",
    "output/legacy.d.ts",
    "output/app",
    "output/element",
    "output/render",
    "output/signal",
    "output/logger"
  ],
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc",
    "build:minify": "node scripts/minify.mjs",
    "postbuild": "npm run build:minify",
    "lint": "eslint source",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "benchmark": "node --experimental-vm-modules benchmark/runner.mjs"
  },
  "dependencies": {
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@typescript-eslint/typescript-estree": "^8.35.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "jsdom": "^26.1.0",
    "signal-polyfill": "^0.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/airxjs/airx"
  },
  "author": "yinxulai",
  "license": "MIT"
}
