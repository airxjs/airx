{
  "name": "airx",
  "version": "0.7.1",
  "description": "a front framework with jsx",
  "type": "module",
  "types": "./output/index.d.ts",
  "exports": {
    ".": {
      "types": "./output/index.d.ts",
      "import": "./output/index.js",
      "default": "./output/index.js"
    }
  },
  "files": [
    "output/*"
  ],
  "scripts": {
    "dev": "vite build -w",
    "build": "vite build",
    "lint": "eslint source",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@typescript-eslint/typescript-estree": "^8.35.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^8.57.0",
    "jsdom": "^26.1.0",
    "signal-polyfill": "^0.2.2",
    "typescript": "^5.4.5",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/airxjs/airx"
  },
  "author": "yinxulai",
  "license": "MIT"
}
