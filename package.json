{
  "name": "airx",
  "version": "0.6.0-beta.1",
  "description": "a front framework with jsx",
  "type": "module",
  "main": "./output/index.umd.cjs",
  "module": "./output/index.js",
  "exports": {
    ".": {
      "import": "./output/index.js",
      "types": "./output/index.d.ts",
      "require": "./output/index.umd.cjs"
    }
  },
  "files": [
    "output/*"
  ],
  "scripts": {
    "dev": "vite build -w",
    "build": "vite build",
    "lint": "eslint source",
